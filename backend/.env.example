# APS Admin Local Backend - Environment Variables Template
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=production

# JWT signing secrets
# Generate each value separately:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_random_64_hex_characters
JWT_REFRESH_SECRET=replace_with_a_different_random_64_hex_character_value
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# CORS Allowed Origins (comma-separated)
# For development: include http://localhost:5173
# For production: include app://aps-admin
ALLOWED_ORIGINS=http://localhost:5173,app://aps-admin

# Allowed Admin Emails (comma-separated)
# IMPORTANT: Only these emails can access the API
ALLOWED_EMAILS=admin@example.com,manager@example.com

# GCP Firestore & Storage
# Project ID is automatically detected from service account JSON
STORAGE_BUCKET=aps-list.appspot.com

# GCP Service Account JSON Path
# 로컬 개발: 절대 경로 지정 (예: E:/Projects/APS/APS_APP/backend-local/service-account.json)
# 도커 환경: /app/service-account.json (docker-compose.yml에서 볼륨 마운트됨)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# Naver OAuth Credentials
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
NAVER_REDIRECT_URI=app://aps-admin/naver-callback

# Aligo SMS API Credentials
ALIGO_API_KEY=your_aligo_api_key_here
ALIGO_USER_ID=your_aligo_user_id_here
ALIGO_SENDER_PHONE=01012345678

# Fixed-IP SMS Relay Server for Aligo whitelist
SMS_RELAY_URL=http://136.113.67.193:3000
# Optional shared bearer token if the relay is configured to require one
# SMS_RELAY_AUTH_TOKEN=

# Direct Electron app operation
# false means normal app HTTP and Socket.IO traffic goes directly to this backend.
# SMS still uses SMS_RELAY_URL above.
WS_RELAY_ENABLED=false
# WS_RELAY_URL=ws://localhost:8080
BACKEND_ENVIRONMENT=production

# ZOHO Mail integration
ZOHO_ENABLED=false
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNT_EMAIL=
ZOHO_FROM_DISPLAY_NAME=행정사법인 APS컨설팅
ZOHO_REDIRECT_URI=
ZOHO_WEBHOOK_SECRET=

# Email AI translation via OpenRouter
# Keep this key on the backend only. Never expose it to the Electron app.
OPENROUTER_API_KEY=
OPENROUTER_TRANSLATION_MODEL=google/gemini-3.1-flash-lite
# Alternative higher-capability model if needed:
# OPENROUTER_TRANSLATION_MODEL=google/gemini-3-flash-preview
OPENROUTER_HTTP_REFERER=https://apsconsulting.kr
OPENROUTER_APP_TITLE=APS Admin Email Translation
EMAIL_TRANSLATION_MAX_CHARS=12000

# Email response attachments
JSON_BODY_LIMIT=35mb
EMAIL_ATTACHMENT_MAX_COUNT=10
EMAIL_ATTACHMENT_MAX_BYTES=20971520
EMAIL_ATTACHMENT_TOTAL_MAX_BYTES=26214400

# Token Encryption Key (32 bytes hex = 64 hex characters)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Keep this secret! Used to encrypt ZOHO OAuth tokens in Firestore
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here_replace_this_value
