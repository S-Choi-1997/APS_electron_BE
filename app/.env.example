# Optional local development defaults for the renderer fallback.
# Release builds should use scripts/build-app-release.ps1 instead of copying this
# file to app/.env. The release script passes a temporary env file through
# APS_APP_CONFIG_ENV_FILE so local app/.env is not overwritten.

VITE_API_URL=https://backend.apsconsulting.kr
VITE_BACKEND_ENVIRONMENT=production

# Optional. If omitted, the app derives wss:// from VITE_API_URL.
# VITE_WS_URL=wss://backend.apsconsulting.kr
