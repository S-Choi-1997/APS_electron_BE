# Copy this file to nas-deploy/.env on the NAS and fill in real values.
# Do not commit nas-deploy/.env.

PORT=3001
NODE_ENV=production
BACKEND_IMAGE_TAG=replace_with_released_backend_version
POSTGRES_PASSWORD=replace_with_strong_postgres_password
DATABASE_URL=postgresql://apsuser:replace_with_url_encoded_postgres_password@postgres:5432/aps_admin

# Auth
# Generate each value separately:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_random_64_hex_characters
JWT_REFRESH_SECRET=replace_with_a_different_random_64_hex_character_value
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
ALLOWED_EMAILS=admin@example.com
ALLOWED_ORIGINS=

# GCP Firebase/Storage
STORAGE_BUCKET=aps-list

# Direct Electron app operation.
# Keep false for direct app-to-backend HTTP and Socket.IO traffic.
WS_RELAY_ENABLED=false
BACKEND_ENVIRONMENT=production

# SMS keeps using the fixed-IP relay path.
SMS_RELAY_URL=http://136.113.67.193:3000
# Optional shared bearer token if the relay is configured to require one
# SMS_RELAY_AUTH_TOKEN=
ALIGO_API_KEY=your_aligo_api_key
ALIGO_USER_ID=your_aligo_user_id
ALIGO_SENDER_PHONE=01012345678

# Naver OAuth
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=app://aps-admin/naver-callback

# ZOHO Mail integration is optional.
ZOHO_ENABLED=false
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNT_EMAIL=
ZOHO_FROM_DISPLAY_NAME=행정사법인 APS컨설팅
ZOHO_REDIRECT_URI=
ZOHO_WEBHOOK_SECRET=

# Email AI translation via OpenRouter.
# Keep this backend-only; do not put it in the Electron app.
OPENROUTER_API_KEY=
OPENROUTER_TRANSLATION_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_HTTP_REFERER=https://apsconsulting.kr
OPENROUTER_APP_TITLE=APS Admin Email Translation
EMAIL_TRANSLATION_MAX_CHARS=12000

# Email response attachments
JSON_BODY_LIMIT=35mb
EMAIL_ATTACHMENT_MAX_COUNT=10
EMAIL_ATTACHMENT_MAX_BYTES=20971520
EMAIL_ATTACHMENT_TOTAL_MAX_BYTES=26214400

# Token Encryption Key (32 bytes hex = 64 hex characters)
ENCRYPTION_KEY=replace_with_random_64_hex_characters
